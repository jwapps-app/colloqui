# Colloqui environment — copy to .env and fill in
# Rename-safe: the product name appears nowhere in here

# Published image to run in production (docker-compose.prod.yml). Point this at
# your registry path, e.g. ghcr.io/youruser/colloqui:latest, or pin a release
# like :v1.2.0. (Ignored by docker-compose.yml, which builds from source.)
COLLOQUI_IMAGE=ghcr.io/CHANGEME/colloqui:latest

# Strong random value, e.g. `openssl rand -base64 24`
POSTGRES_PASSWORD=change-me

# Host port the API (and web UI) is exposed on
API_PORT=3300

# Where persistent data (database, uploads, backups) is stored on the host.
# Defaults to ./data next to this file. On a Synology NAS, e.g.:
#   DATA_DIR=/volume1/docker/colloqui/data
DATA_DIR=./data

# WebAuthn relying-party ID = the domain passkeys are bound to.
# Dev: localhost   Production: jjrrr.co (the apex, NOT the subdomain — this
# keeps every passkey valid if the product/subdomain is ever renamed)
RP_ID=localhost

# Exact browser origin, scheme + host + port.
# Dev: http://localhost:3300   Production: https://colloqui.jjrrr.co
ORIGIN=http://localhost:3300

# true enables /docs (Swagger). Keep false in production.
DEV_MODE=true

# --- iOS push notifications (APNs) ---
# Leave these blank to keep push off. To enable:
#   1. Apple Developer portal -> Keys -> create an APNs auth key, download the
#      .p8 ONCE, and note its Key ID.
#   2. Put the .p8 next to docker-compose.prod.yml as AuthKey.p8 and uncomment
#      the apns.p8 volume mount in that file.
#   3. Fill in the values below and redeploy.
APNS_KEY_ID=
APNS_TEAM_ID=SXR7R3LC4M
APNS_TOPIC=com.jworthington.colloqui
# false = production APNs (TestFlight / App Store builds). true only for builds
# run directly from Xcode onto a device (sandbox).
APNS_SANDBOX=false
